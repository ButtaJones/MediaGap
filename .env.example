PORT=4174
DATABASE_PATH=./data/app.db

# Trakt integration (optional). Register one app at https://trakt.tv/oauth/applications
# (use "urn:ietf:wg:oauth:2.0:oob" as the redirect URI for the device-code flow), then set
# both values below. Leave blank to disable the Trakt feature. The secret is read server-side
# only and must never be committed.
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
